{
  "llama_bin": "D:\\llama-cpp",
  "models_dir": "D:\\.lmstudio\\models",
  "port": 1234,
  "backend_port_start": 11000,
  "idle_timeout_secs": 300,
  "vram_budget_mb": 14000,
  "models": {
    "code": {

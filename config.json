      "vram_mb": 4600
    }
  },
  "connectors": {
    "vision": {
      "type": "python",
      "script": "connectors/vision/vision_connector.py",
      "args": ["--all"],
      "description": "MediaPipe hand/pose/segmentation → wavehaze shared memory",
      "shm_name": "WaveHaze_Vision",
      "camera": 0
    }
  },
  "prompts": {
    "name_chat": {
      "model": "naming",
      "system": "You are a chat naming assistant. Given a conversation, output ONLY a short title (2-6 words). No quotes, no explanation, no punctuation at the end.",
      "max_tokens": 20,
      "temperature": 0.3
    },
    "summarize_chat": {
      "model": "code",
      "system": "You are a technical summarizer. Given a chat transcript, produce a structured handoff summary in markdown with sections: ## What Was Done, ## Open Items, ## Key Decisions. Be concise and specific.",
      "max_tokens": 512,
      "temperature": 0.2
    }
  }
}

      "gpu_layers": 99,
      "ctx_size": 8192,
      "flash_attn": true,
      "description": "Code generation, GLSL shaders, technical tasks",
      "vram_mb": 5014
    },
    "naming": {
      "path": "lmstudio-community/Qwen2.5-0.5B-Instruct-GGUF/Qwen2.5-0.5B-Instruct-Q8_0.gguf",
      "gpu_layers": 99,
      "ctx_size": 2048,
      "flash_attn": true,
      "description": "Chat naming, classification, lightweight tasks",
      "vram_mb": 825
    },
    "deepseek": {
      "path": "lmstudio-community/DeepSeek-Coder-V2-Lite-Instruct-GGUF/DeepSeek-Coder-V2-Lite-Instruct-Q4_K_M.gguf",
      "gpu_layers": 99,
      "ctx_size": 8192,
      "flash_attn": true,
      "description": "87 languages, strong GLSL, MoE",
      "vram_mb": 9700
    },
    "phi4": {
      "path": "lmstudio-community/phi-4-GGUF/phi-4-Q4_K_M.gguf",
      "gpu_layers": 99,
      "ctx_size": 4096,
      "flash_attn": true,
      "description": "General purpose reasoning",
      "vram_mb": 8500
    },
    "llama31": {
      "path": "lmstudio-community/Meta-Llama-3.1-8B-Instruct-GGUF/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf",
